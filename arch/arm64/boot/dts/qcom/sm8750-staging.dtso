					remote-endpoint = <&ncc1_0_rep_in>;
				};
			};
		};
	};

	etm-7 {
		compatible = "arm,coresight-etm4x-sysreg";

		clocks = <&aoss_qmp>;
		clock-names = "apb_pclk";
		cpu = <&cpu7>;
		qcom,skip-power-up;

		out-ports {
