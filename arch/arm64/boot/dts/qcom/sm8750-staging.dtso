/dts-v1/;
/plugin/;

&{/} {
	etm-0 {
		compatible = "arm,coresight-etm4x-sysreg";

		clocks = <&aoss_qmp>;
		clock-names = "apb_pclk";
		cpu = <&cpu0>;
		qcom,skip-power-up;

		out-ports {
			port {
				etm0_out: endpoint {
					remote-endpoint = <&ncc0_0_rep_in>;
				};
			};
		};
	};

	etm-1 {
		compatible = "arm,coresight-etm4x-sysreg";

		clocks = <&aoss_qmp>;
		clock-names = "apb_pclk";
		cpu = <&cpu1>;
		qcom,skip-power-up;

		out-ports {
			port {
				etm1_out: endpoint {
					remote-endpoint = <&ncc0_1_rep_in>;
				};
			};
		};
	};

	etm-2 {
		compatible = "arm,coresight-etm4x-sysreg";

