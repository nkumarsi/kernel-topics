		arm,smc-id = <0xc6008012>;
		shmem = <&shmem25>;
		/* We expect the bootloader to update the IRQ number */
		interrupts = <GIC_ESPI 0 IRQ_TYPE_EDGE_RISING>;
		interrupt-names = "a2p";
		#address-cells = <1>;
		#size-cells = <0>;
		arm,max-msg = <10>;
		arm,max-msg-size = <256>;
		arm,max-rx-timeout-ms = <3000>;

		status = "disabled";

		scmi25_pd: protocol@11 {
			reg = <0x11>;
			#power-domain-cells = <1>;
		};

