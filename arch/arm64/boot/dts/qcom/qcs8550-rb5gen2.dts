		vdd-l5-supply = <&vreg_s6g_1p86>;
		vdd-l6-supply = <&vreg_s6g_1p86>;
		vdd-l7-supply = <&vreg_bob1>;

		qcom,pmic-id = "m";

		vreg_l1m_1p056: ldo1 {
